# Optional: enable Kylit Telegram backup commands (same binary as clos-monitor).
# Copy relevant lines into /etc/clos-monitor.env or your MONITOR_ENV_FILE.

MONITOR_KYLIT_WEBHOOK=1

# Deploy directory on server (Makefile DEPLOY_PATH default)
KYLIT_DEPLOY_PATH=/home/kylit/kylit

# Sourced by scripts/kylit-prod-backup.sh for POSTGRES_USER / POSTGRES_DB
KYLIT_ENV_FILE=/home/kylit/kylit/.env.prod

KYLIT_PG_CONTAINER=kylit-postgres
KYLIT_BACKUP_ROOT=/var/backups/kylit

# Optional: override script path
# KYLIT_BACKUP_SCRIPT=/home/kylit/kylit/scripts/kylit-prod-backup.sh

# MinIO Client aliases (configure with: mc alias set kylit-prod ...; mc alias set kylit-archive ...)
SRC_ALIAS=kylit-prod
DST_ALIAS=kylit-archive

# Optional extras for kylit-prod-backup.sh
# KYLIT_BACKUP_SECOND_DIR=/mnt/extra/kylit-backups
# RCLONE_REMOTE=myremote:kylit-offsite

# --- Generic stack / IP admin (see docs/SETUP.md) ---
# MONITOR_PROCESS_COMM=clos-monitor,server-monitor
# MONITOR_PROD_CONTAINERS=closlamartine_db,closlamartine_backend,closlamartine_frontend
# MONITOR_STAGING_CONTAINERS=clsmstaging_db,clsmstaging_backend,clsmstaging_frontend
# MONITOR_PROD_COMPOSE_RESTART_SH=docker compose --env-file .env.prod -p closlamartine -f docker-compose.prod.yml restart 2>&1
# MONITOR_STAGING_COMPOSE_RESTART_SH=docker compose --env-file .env.staging -p clsmstaging -f docker-compose.staging.yml restart 2>&1

